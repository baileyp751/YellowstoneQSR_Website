---
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Technology Ticket Dashboard</title>

  <style>
    :root {
      color-scheme: dark;
      --panel: rgba(15, 23, 42, 0.84);
      --soft: rgba(30, 41, 59, 0.68);
      --border: rgba(148, 163, 184, 0.18);
      --text: #f8fafc;
      --muted: #94a3b8;
      --muted2: #64748b;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      background:
        radial-gradient(circle at 18% 0%, rgba(56, 189, 248, 0.12), transparent 32rem),
        radial-gradient(circle at 88% 8%, rgba(129, 140, 248, 0.12), transparent 30rem),
        linear-gradient(180deg, #020617 0%, #020617 55%, #030712 100%);
      color: var(--text);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .page-wrap {
      width: min(100%, 1280px);
      margin: 0 auto;
      padding: 32px;
    }

    header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 24px;
      margin-bottom: 26px;
    }

    header > div:first-child { max-width: 920px; }
    header > div:last-child { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }

    #organizationName {
      margin: 0;
      color: #7dd3fc;
      font-size: 13px;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      font-weight: 800;
    }

    #dashboardTitle {
      margin: 8px 0 0;
      font-size: clamp(34px, 4vw, 52px);
      line-height: 1;
      letter-spacing: -0.045em;
      font-weight: 950;
      color: #fff;
    }

    p { color: var(--muted); }

    .help-box {
      margin-top: 16px;
      border-radius: 18px;
      border: 1px solid var(--border);
      background: rgba(2, 6, 23, 0.62);
      padding: 16px;
      color: #cbd5e1;
    }

    .help-box ul { margin: 8px 0 0; padding: 0; list-style: none; }
    .help-box li { margin-top: 5px; color: var(--muted); font-size: 14px; }

    .card,
    .last-updated,
    #errorBox {
      background: var(--panel);
      border: 1px solid var(--border);
      box-shadow: 0 18px 50px rgba(0, 0, 0, 0.25);
      backdrop-filter: blur(8px);
    }

    .card {
      border-radius: 28px;
      padding: 22px;
      margin-bottom: 24px;
    }

    .soft {
      background: var(--soft);
      border: 1px solid rgba(148, 163, 184, 0.14);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
      border-radius: 28px;
      padding: 20px;
      min-height: 138px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      text-align: center;
    }

    .pill {
      border: 1px solid rgba(148, 163, 184, 0.22);
      background: rgba(15, 23, 42, 0.72);
      border-radius: 999px;
    }

    button { cursor: pointer; font: inherit; }

    #refreshBtn {
      border: 0;
      border-radius: 18px;
      background: #38bdf8;
      color: #020617;
      padding: 13px 20px;
      font-size: 14px;
      font-weight: 900;
      box-shadow: 0 16px 40px rgba(2, 132, 199, 0.20);
    }

    #refreshBtn:hover { background: #7dd3fc; }

    .last-updated {
      border-radius: 18px;
      padding: 12px 16px;
      font-size: 14px;
      color: #cbd5e1;
    }

    .last-updated-label {
      color: var(--muted2);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: .08em;
    }

    #errorBox {
      display: none;
      border-color: rgba(248, 113, 113, 0.35);
      background: rgba(127, 29, 29, 0.48);
      color: #fee2e2;
      border-radius: 18px;
      padding: 16px;
      margin-bottom: 24px;
    }

    #errorBox:not(.hidden) { display: block; }
    .hidden { display: none !important; }
    .flex { display: flex !important; }

    .section-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }

    section h2 {
      margin: 0;
      font-size: 22px;
      font-weight: 900;
      letter-spacing: -0.02em;
    }

    .grid { display: grid; }
    .metric-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; }
    .breakdown-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 24px; }

    .metric-label { margin: 0; color: var(--muted); font-size: 14px; }

    .metric-value {
      margin-top: 8px;
      font-size: clamp(36px, 4vw, 48px);
      font-weight: 950;
      color: #fff;
      line-height: 1;
    }

    .metric-note { margin: 8px 0 0; color: var(--muted2); font-size: 12px; }
    #perfAvgResolution, #oldestOpen { font-size: clamp(28px, 3vw, 38px); }

    select,
    input {
      width: 100%;
      border: 1px solid rgba(51, 65, 85, 0.95);
      background: rgba(2, 6, 23, 0.88);
      color: #f8fafc;
      border-radius: 14px;
      padding: 10px 12px;
      outline: none;
      font: inherit;
    }

    select:focus,
    input:focus {
      border-color: rgba(56, 189, 248, 0.7);
      box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.15);
    }

    input:disabled { opacity: 0.45; }

    label span {
      display: block;
      margin-bottom: 4px;
      color: var(--muted2);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: .08em;
      font-weight: 800;
    }

    .period-controls {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
      min-width: min(100%, 560px);
    }

    #storeBreakdown,
    #patchBreakdown,
    #otpBreakdown {
      max-height: 650px;
      overflow-y: auto;
      padding-right: 8px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .breakdown-card-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 16px;
    }

    .breakdown-card-head .pill {
      padding: 4px 12px;
      font-size: 12px;
      color: #cbd5e1;
      white-space: nowrap;
    }

    .empty-breakdown {
      color: #94a3b8;
      font-size: 14px;
      padding: 12px;
    }

    table { width: 100%; border-collapse: collapse; }
    thead { background: rgba(15, 23, 42, 0.9); color: var(--muted2); text-transform: uppercase; font-size: 12px; letter-spacing: 0.08em; }
    th, td { padding: 12px; vertical-align: top; text-align: left; }
    .table-row { border-top: 1px solid var(--border); }
    .table-row:hover { background: rgba(51, 65, 85, 0.48); }

    #ticketModal {
      position: fixed;
      inset: 0;
      z-index: 50;
      display: none;
      align-items: center;
      justify-content: center;
      background: rgba(0,0,0,0.72);
      padding: 16px;
      backdrop-filter: blur(5px);
    }

    #ticketModal.flex { display: flex !important; }

    #ticketModal > div {
      width: min(100%, 1152px);
      max-height: 90vh;
      display: flex;
      flex-direction: column;
    }

    .modal-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      border-bottom: 1px solid var(--border);
      padding: 20px;
    }

    #modalTitle { margin: 0; font-size: 28px; font-weight: 900; }
    #modalSubtitle { margin: 4px 0 0; color: var(--muted); font-size: 14px; }
    #modalTicketList { overflow: auto; padding: 20px; }

    #closeModal {
      border-radius: 12px;
      border: 1px solid rgba(148, 163, 184, 0.35);
      background: transparent;
      color: #e2e8f0;
      padding: 8px 16px;
      font-weight: 800;
    }

    #closeModal:hover { background: rgba(30, 41, 59, 0.7); }

    .ticket-detail-card {
      margin-bottom: 16px;
      border-radius: 18px;
      border: 1px solid var(--border);
      background: rgba(2, 6, 23, 0.72);
      padding: 16px;
    }

    .ticket-detail-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .detail-label {
      color: var(--muted2);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: .08em;
      font-weight: 900;
      margin: 0;
    }

    .detail-value { color: #e2e8f0; font-size: 14px; margin: 4px 0 0; }
    .whitespace-pre-wrap { white-space: pre-wrap; }
    .overflow-x-auto { overflow-x: auto; }

    .ticket-link {
      background: none;
      border: 0;
      color: #bae6fd;
      text-align: left;
      font-weight: 800;
      padding: 0;
    }


    [data-breakdown-type]:hover {
      background: rgba(30, 41, 59, .65) !important;
      border-color: rgba(56, 189, 248, .35) !important;
    }

    [data-breakdown-type]:hover .breakdown-fill {
      filter: brightness(1.15);
    }

    .breakdown-track {
      height: 8px;
      width: 100%;
      border-radius: 999px;
      overflow: hidden;
      background: rgba(51, 65, 85, .82);
    }

    .breakdown-fill {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(
        90deg,
        #38bdf8 0%,
        #60a5fa 55%,
        #818cf8 100%
      );
      box-shadow: 0 0 10px rgba(56, 189, 248, .22);
    }

    @media (max-width: 1180px) {
      .breakdown-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 920px) {
      .page-wrap { padding: 22px; }
      header { flex-direction: column; }
      .metric-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .period-controls { grid-template-columns: repeat(2, minmax(0, 1fr)); min-width: 0; width: 100%; }
    }

    @media (max-width: 560px) {
      .page-wrap { padding: 16px; }
      .metric-grid, .period-controls, .ticket-detail-grid { grid-template-columns: 1fr; }
      #dashboardTitle { font-size: 34px; }
    }
  </style>
</head>

<body>
  <div class="page-wrap">
    <header>
      <div>
        <p id="organizationName">Organization Name</p>
        <h1 id="dashboardTitle">Technology Ticket Dashboard</h1>
        <div style="margin-top: 12px;">
          <p style="max-width: 780px; margin: 0; font-size: 14px;">
            Live dashboard pulling open and closed ticket data from NocoDB. Counts update automatically as tickets are added, changed, or closed.
          </p>
        </div>
        <div class="help-box">
          <div style="font-weight: 900; color: #f8fafc; margin-bottom: 8px;">How to Read This Dashboard</div>
          <ul>
            <li>• Performance Metrics are based on the selected performance period.</li>
            <li>• Organization Overview is all-time and does not change with the performance period.</li>
            <li>• Open Tickets = any ticket not currently closed.</li>
            <li>• Store, Patch, and OTP charts only count currently open tickets.</li>
            <li>• Click a store, patch, or OTP to drill into open tickets, then click a ticket number for details.</li>
          </ul>
        </div>
      </div>

      <div>
        <div class="last-updated">
          <div class="last-updated-label">Last Updated</div>
          <div id="lastUpdated" style="font-weight: 800; color: #f8fafc;">Loading...</div>
        </div>
        <button id="refreshBtn">Refresh</button>
      </div>
    </header>

    <div id="errorBox" class="hidden"></div>

    <section class="card">
      <div class="section-head">
        <div>
          <h2>Performance Metrics</h2>
          <p id="performanceSubtitle" style="margin: 4px 0 0; font-size: 14px;">
            Metrics based on the selected performance period.
          </p>
        </div>

        <div class="period-controls">
          <label>
            <span>Performance Period</span>
            <select id="performancePeriodFilter">
              <option value="currentMonth">Current Month</option>
              <option value="lastMonth">Last Month</option>
              <option value="last7">Last 7 Days</option>
              <option value="last30">Last 30 Days</option>
              <option value="last90">Last 90 Days</option>
              <option value="all">All Time</option>
              <option value="custom">Custom Range</option>
            </select>
          </label>

          <label>
            <span>Start Date</span>
            <input id="performanceStartDate" type="date" disabled />
          </label>

          <label>
            <span>End Date</span>
            <input id="performanceEndDate" type="date" disabled />
          </label>
        </div>
      </div>

      <div class="grid metric-grid">
        <div class="soft">
          <p class="metric-label">Tickets Opened</p>
          <div id="perfOpened" class="metric-value">--</div>
          <p class="metric-note">Created in period</p>
        </div>

        <div class="soft">
          <p class="metric-label">Tickets Closed</p>
          <div id="perfClosed" class="metric-value">--</div>
          <p class="metric-note">Closed in period</p>
        </div>

        <div class="soft">
          <p class="metric-label">Avg Resolution</p>
          <div id="perfAvgResolution" class="metric-value">--</div>
          <p id="perfAvgResolutionNote" class="metric-note">Requires Created + Last Modified</p>
        </div>

        <div class="soft">
          <p class="metric-label">Close Rate</p>
          <div id="perfCloseRate" class="metric-value">--</div>
          <p class="metric-note">Closed ÷ Opened</p>
        </div>
      </div>
    </section>

    <section class="card">
      <div class="section-head">
        <div>
          <h2>Organization Overview</h2>
          <p style="margin: 4px 0 0; font-size: 14px;">
            All-time organization health and accountability metrics.
          </p>
        </div>
      </div>

      <div class="grid metric-grid">
        <div class="soft">
          <p class="metric-label">Open Tickets</p>
          <div id="openCount" class="metric-value">--</div>
          <p class="metric-note">Anything not closed</p>
        </div>

        <div class="soft">
          <p class="metric-label">Closed Tickets</p>
          <div id="closedCount" class="metric-value">--</div>
          <p class="metric-note">Archived / closed view</p>
        </div>

        <div class="soft">
          <p class="metric-label">Total Tickets</p>
          <div id="totalCount" class="metric-value">--</div>
          <p class="metric-note">Open + closed</p>
        </div>

        <div class="soft">
          <p class="metric-label">Oldest Open</p>
          <div id="oldestOpen" class="metric-value">--</div>
          <p id="oldestOpenNote" class="metric-note">Longest aging open ticket</p>
        </div>
      </div>
    </section>

    <section class="grid breakdown-grid">
      <div class="card">
        <div class="breakdown-card-head">
          <h2>Open Tickets by Store</h2>
          <span class="pill">Click a store</span>
        </div>
        <div id="storeBreakdown"></div>
      </div>

      <div class="card">
        <div class="breakdown-card-head">
          <h2>Open Tickets by Supervisor Area / Patch</h2>
          <span class="pill">Click a patch</span>
        </div>
        <div id="patchBreakdown"></div>
      </div>

      <div class="card">
        <div class="breakdown-card-head">
          <h2>Open Tickets by OTP</h2>
          <span class="pill">Click an OTP</span>
        </div>
        <div id="otpBreakdown"></div>
      </div>
    </section>
  </div>

  <div id="ticketModal" class="hidden">
    <div class="card">
      <div class="modal-head">
        <div>
          <h2 id="modalTitle">Tickets</h2>
          <p id="modalSubtitle"></p>
        </div>
        <button id="closeModal">Close</button>
      </div>
      <div id="modalTicketList"></div>
    </div>
  </div>

  <script>
    const CONFIG = {
      organizationName: 'Yellowstone QSR',
      dashboardTitle: 'Technology Ticket Dashboard',
      apiUrl: '/api/ticket-dashboard',
      refreshMinutes: 5
    };

    const state = {
      open: [],
      closed: [],
      all: []
    };

    const els = {
      lastUpdated: document.getElementById('lastUpdated'),
      errorBox: document.getElementById('errorBox'),
      refreshBtn: document.getElementById('refreshBtn'),
      perfOpened: document.getElementById('perfOpened'),
      perfClosed: document.getElementById('perfClosed'),
      perfAvgResolution: document.getElementById('perfAvgResolution'),
      perfAvgResolutionNote: document.getElementById('perfAvgResolutionNote'),
      perfCloseRate: document.getElementById('perfCloseRate'),
      performanceSubtitle: document.getElementById('performanceSubtitle'),
      performancePeriodFilter: document.getElementById('performancePeriodFilter'),
      performanceStartDate: document.getElementById('performanceStartDate'),
      performanceEndDate: document.getElementById('performanceEndDate'),
      openCount: document.getElementById('openCount'),
      closedCount: document.getElementById('closedCount'),
      totalCount: document.getElementById('totalCount'),
      oldestOpen: document.getElementById('oldestOpen'),
      oldestOpenNote: document.getElementById('oldestOpenNote'),
      storeBreakdown: document.getElementById('storeBreakdown'),
      patchBreakdown: document.getElementById('patchBreakdown'),
      otpBreakdown: document.getElementById('otpBreakdown'),
      ticketModal: document.getElementById('ticketModal'),
      modalTitle: document.getElementById('modalTitle'),
      modalSubtitle: document.getElementById('modalSubtitle'),
      modalTicketList: document.getElementById('modalTicketList'),
      closeModal: document.getElementById('closeModal')
    };

    function normalizeRecord(record) {
      const f = record.fields || record;
      const archived = f.Archived === 1 || f.Archived === true || f.Archived === '1';
      const source = archived ? 'closed' : 'open';

      return {
        raw: record,
        source,
        id: record.id || f.Id,
        ticketNumber: f['Ticket Number'] ?? f.Id ?? record.id,
        archived: archived ? 1 : 0,
        status: f.Status || (archived ? 'Closed' : 'New Ticket'),
        reporter: f['Reporter Name'] || '',
        category: f['Device Affected'] || f.Category || 'Uncategorized',
        issue: f['Issue Description'] || '',
        notes: f.Notes || '',
        created: f.Created || f['Created time'] || f['Created Time'] || f['Created At'] || null,
        modified: f['Last Modified'] || f['Last modified time'] || f['Last Modified Time'] || f.Updated || f['Updated At'] || null,
        store: f['Store Name/Number'] || f['Store Number - Name'] || 'No Store Listed',
        patch: f.Patch || f['Supervisor Patch'] || 'No Patch Listed',
        otp: normalizeOtp(f['OTP Name Link'] || f['OTP Assigned'] || f['OTP Name'] || f.OTP),
        hasAttachment: Array.isArray(f.Attachment) && f.Attachment.length > 0
      };
    }

    function normalizeOtp(value) {
      if (!value) return 'No OTP Listed';

      if (Array.isArray(value)) {
        const names = value.map(item => {
          if (typeof item === 'string') return item;

          return item.display_name
            || item.title
            || item.name
            || item['OTP Name']
            || item.Name
            || item.email
            || '';
        }).filter(Boolean);

        return names.length ? names.join(', ') : 'No OTP Listed';
      }

      if (typeof value === 'object') {
        return value.display_name
          || value.title
          || value.name
          || value['OTP Name']
          || value.Name
          || value.email
          || 'No OTP Listed';
      }

      return String(value);
    }

    function escapeHtml(value) {
      return String(value ?? '').replace(/[&<>'"]/g, c => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        "'": '&#39;',
        '"': '&quot;'
      }[c]));
    }

    function formatDate(value) {
      if (!value) return '';

      const d = new Date(value);

      if (Number.isNaN(d.getTime())) return value;

      return d.toLocaleString([], {
        month: 'short',
        day: 'numeric',
        year: 'numeric',
        hour: 'numeric',
        minute: '2-digit'
      });
    }

    function formatAge(value) {
      if (!value) return 'Unknown';

      const d = new Date(value);

      if (Number.isNaN(d.getTime())) return 'Unknown';

      const days = Math.floor((Date.now() - d.getTime()) / 86400000);

      if (days < 1) return 'Today';
      if (days === 1) return '1 day';

      return `${days} days`;
    }

    function formatDuration(ms) {
      if (!Number.isFinite(ms) || ms < 0) return 'Unavailable';

      const hours = ms / 3600000;

      return hours < 48
        ? `${hours.toFixed(1)} hrs`
        : `${(hours / 24).toFixed(1)} days`;
    }

    function averageClosureTime(closed) {
      const durations = closed.map(ticket => {
        if (!ticket.created || !ticket.modified) return null;

        const start = new Date(ticket.created).getTime();
        const end = new Date(ticket.modified).getTime();

        return Number.isFinite(start) && Number.isFinite(end) && end >= start
          ? end - start
          : null;
      }).filter(value => value !== null);

      if (!durations.length) {
        return {
          text: 'Unavailable',
          count: 0
        };
      }

      return {
        text: formatDuration(durations.reduce((a, b) => a + b, 0) / durations.length),
        count: durations.length
      };
    }

    function getMonthBounds(offset = 0) {
      const now = new Date();
      const start = new Date(now.getFullYear(), now.getMonth() + offset, 1);
      const end = new Date(now.getFullYear(), now.getMonth() + offset + 1, 0, 23, 59, 59, 999);

      return { start, end };
    }

    function getPeriodBounds(type, startValue, endValue) {
      let start = null;
      let end = null;
      let label = 'All Time';

      if (type === 'currentMonth') {
        ({ start, end } = getMonthBounds(0));
        label = start.toLocaleString([], { month: 'long', year: 'numeric' });
      }

      if (type === 'lastMonth') {
        ({ start, end } = getMonthBounds(-1));
        label = start.toLocaleString([], { month: 'long', year: 'numeric' });
      }

      if (type === 'last7') {
        end = new Date();
        start = new Date();
        start.setDate(start.getDate() - 7);
        label = 'Last 7 Days';
      }

      if (type === 'last30') {
        end = new Date();
        start = new Date();
        start.setDate(start.getDate() - 30);
        label = 'Last 30 Days';
      }

      if (type === 'last90') {
        end = new Date();
        start = new Date();
        start.setDate(start.getDate() - 90);
        label = 'Last 90 Days';
      }

      if (type === 'custom') {
        start = startValue ? new Date(`${startValue}T00:00:00`) : null;
        end = endValue ? new Date(`${endValue}T23:59:59`) : null;
        label = `${startValue || '...'} → ${endValue || '...'}`;
      }

      return { start, end, label };
    }

    function inRange(value, bounds) {
      if (!value) return false;

      if (!bounds.start && !bounds.end) return true;

      const d = new Date(value);

      if (Number.isNaN(d.getTime())) return false;
      if (bounds.start && d < bounds.start) return false;
      if (bounds.end && d > bounds.end) return false;

      return true;
    }

    function countBy(items, key) {
      return items.reduce((acc, item) => {
        const value = item[key] || 'Blank';
        acc[value] = (acc[value] || 0) + 1;
        return acc;
      }, {});
    }

    function sortedEntries(obj) {
      return Object.entries(obj).sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
    }

    function renderSummary() {
      els.openCount.textContent = state.open.length.toLocaleString();
      els.closedCount.textContent = state.closed.length.toLocaleString();
      els.totalCount.textContent = state.all.length.toLocaleString();

      const oldestTicket = [...state.open]
        .filter(ticket => ticket.created)
        .sort((a, b) => new Date(a.created) - new Date(b.created))[0];

      if (oldestTicket) {
        els.oldestOpen.textContent = formatAge(oldestTicket.created);
        els.oldestOpenNote.textContent = `Ticket #${oldestTicket.ticketNumber} · ${oldestTicket.store}`;
      } else {
        els.oldestOpen.textContent = '--';
        els.oldestOpenNote.textContent = 'No open tickets';
      }

      renderPerformanceMetrics();
      renderBreakdowns();
    }

    function renderPerformanceMetrics() {
      const bounds = getPeriodBounds(
        els.performancePeriodFilter.value,
        els.performanceStartDate.value,
        els.performanceEndDate.value
      );

      els.performanceSubtitle.textContent = `Metrics based on ${bounds.label}.`;

      const opened = state.all.filter(ticket => inRange(ticket.created, bounds));
      const closed = state.closed.filter(ticket => inRange(ticket.modified || ticket.created, bounds));
      const avg = averageClosureTime(closed);

      els.perfOpened.textContent = opened.length.toLocaleString();
      els.perfClosed.textContent = closed.length.toLocaleString();
      els.perfAvgResolution.textContent = avg.text;
      els.perfAvgResolutionNote.textContent = avg.count
        ? `Based on ${avg.count.toLocaleString()} closed tickets`
        : 'No closed tickets in period';
      els.perfCloseRate.textContent = opened.length
        ? `${Math.round((closed.length / opened.length) * 100)}%`
        : '0%';
    }

    function renderBreakdowns() {
      const openOnly = state.open;

      renderBreakdown(els.storeBreakdown, countBy(openOnly, 'store'), 'store');
      renderBreakdown(els.patchBreakdown, countBy(openOnly, 'patch'), 'patch');
      renderBreakdown(els.otpBreakdown, countBy(openOnly, 'otp'), 'otp');
    }

    function renderBreakdown(container, counts, type) {
      const entries = sortedEntries(counts);
      const max = Math.max(...entries.map(entry => entry[1]), 1);

      container.innerHTML = entries.length
        ? entries.map(([label, count]) => {
          const width = Math.max((count / max) * 100, 6);

          return `
            <div
              role="button"
              tabindex="0"
              data-breakdown-type="${escapeHtml(type)}"
              data-breakdown-label="${escapeHtml(label)}"
              style="
                display:block;
                width:100%;
                padding:12px 14px;
                border-radius:14px;
                cursor:pointer;
                text-align:left;
                color:inherit;
                background:rgba(15,23,42,.35);
                border:1px solid rgba(148,163,184,.08);
                transition:.15s ease;
              "
            >
              <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:6px;font-size:14px;">
                <span style="color:#e2e8f0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;">
                  ${escapeHtml(label)}
                </span>
                <span style="color:#f8fafc;font-weight:900;width:50px;text-align:right;flex-shrink:0;">
                  ${count.toLocaleString()}
                </span>
              </div>
              <div class="breakdown-track">
                <div class="breakdown-fill" style="width:${width}%"></div>
              </div>
            </div>
          `;
        }).join('')
        : '<div class="empty-breakdown">No open tickets found.</div>';
    }

    function sortTicketsForModal(tickets) {
      return tickets.sort((a, b) => new Date(a.created || 0) - new Date(b.created || 0));
    }

    function quickBreakdown(type, label) {
      const tickets = sortTicketsForModal(
        state.open.filter(ticket => {
          if (type === 'store') return ticket.store === label;
          if (type === 'patch') return ticket.patch === label;
          if (type === 'otp') return ticket.otp === label;
          return false;
        })
      );

      const titleType = type === 'store'
        ? 'Store'
        : type === 'patch'
          ? 'Supervisor Patch'
          : 'OTP';

      const columns = type === 'store'
        ? ['ticket', 'issue', 'status', 'category', 'age']
        : ['ticket', 'store', 'issue', 'status', 'category', 'age'];

      els.modalTitle.textContent = `${titleType}: ${label}`;
      els.modalSubtitle.textContent = `${tickets.length.toLocaleString()} open ticket${tickets.length === 1 ? '' : 's'}.`;
      els.modalTicketList.innerHTML = tableMarkup(tickets, {
        limit: 500,
        columns,
        clickableTickets: true
      });

      els.ticketModal.classList.remove('hidden');
      els.ticketModal.classList.add('flex');
    }

    function tableMarkup(items, options) {
      const limit = options.limit || 50;
      const columns = options.columns;
      const clickableTickets = options.clickableTickets || false;

      if (!items.length) {
        return '<div style="padding:16px; color:#94a3b8; font-size:14px;">No tickets found.</div>';
      }

      const headers = {
        ticket: 'Ticket',
        store: 'Store',
        issue: 'Issue',
        status: 'Status',
        category: 'Category',
        age: 'Age'
      };

      const rows = items.slice(0, limit).map(ticket => `
        <tr class="table-row">
          ${columns.map(col => `<td>${cellValue(ticket, col, clickableTickets)}</td>`).join('')}
        </tr>
      `).join('');

      const extra = items.length > limit
        ? `<div style="border-top:1px solid var(--border); padding:12px; text-align:center; color:#64748b; font-size:12px;">Showing first ${limit.toLocaleString()} results.</div>`
        : '';

      return `
        <div class="overflow-x-auto">
          <table>
            <thead>
              <tr>${columns.map(col => `<th>${headers[col]}</th>`).join('')}</tr>
            </thead>
            <tbody>${rows}</tbody>
          </table>
        </div>
        ${extra}
      `;
    }

    function cellValue(ticket, col, clickableTickets = false) {
      if (col === 'ticket') {
        const label = `#${escapeHtml(String(ticket.ticketNumber))}`;
        const meta = `<div style="margin-top:4px; font-size:12px; color:#64748b; font-weight:400;">${escapeHtml(ticket.source.toUpperCase())}${ticket.hasAttachment ? ' · Attachment' : ''}</div>`;

        return clickableTickets
          ? `<button class="ticket-link" type="button" data-ticket-detail="${escapeHtml(String(ticket.ticketNumber))}">${label}${meta}</button>`
          : `${label}${meta}`;
      }

      if (col === 'store') return escapeHtml(ticket.store);
      if (col === 'issue') return escapeHtml(ticket.issue || 'No issue description entered.');
      if (col === 'status') return `<span class="pill" style="padding:4px 8px; font-size:12px;">${escapeHtml(ticket.status)}</span>`;
      if (col === 'category') return escapeHtml(ticket.category);
      if (col === 'age') return escapeHtml(formatAge(ticket.created));

      return '';
    }

    function showTicketDetails(ticketNumber) {
      const ticket = state.all.find(item => String(item.ticketNumber) === String(ticketNumber));

      if (!ticket) return;

      const existing = els.modalTicketList.querySelector('[data-ticket-detail-card]');

      if (existing) existing.remove();

      const detailHtml = `
        <div data-ticket-detail-card class="ticket-detail-card">
          <div style="display:flex; justify-content:space-between; gap:12px; flex-wrap:wrap; margin-bottom:12px;">
            <div>
              <h3 style="margin:0; font-size:22px; font-weight:950; color:#bae6fd;">Ticket #${escapeHtml(String(ticket.ticketNumber))}</h3>
              <p style="margin:4px 0 0; font-size:14px;">${escapeHtml(ticket.store)} · ${escapeHtml(ticket.status)}</p>
            </div>
            <span class="pill" style="height:fit-content; padding:4px 12px; font-size:12px; color:#cbd5e1;">${escapeHtml(ticket.source.toUpperCase())}</span>
          </div>

          <div class="ticket-detail-grid">
            <div><p class="detail-label">Issue</p><p class="detail-value">${escapeHtml(ticket.issue || 'No issue description entered.')}</p></div>
            <div><p class="detail-label">Category</p><p class="detail-value">${escapeHtml(ticket.category)}</p></div>
            <div><p class="detail-label">OTP</p><p class="detail-value">${escapeHtml(ticket.otp)}</p></div>
            <div><p class="detail-label">Created</p><p class="detail-value">${escapeHtml(formatDate(ticket.created) || 'Not available')}</p></div>
          </div>

          <div style="margin-top:16px;">
            <p class="detail-label">Issue Description</p>
            <p class="detail-value whitespace-pre-wrap">${escapeHtml(ticket.issue || 'No issue description entered.')}</p>
          </div>

          <div style="margin-top:16px;">
            <p class="detail-label">Notes</p>
            <p class="detail-value whitespace-pre-wrap">${escapeHtml(ticket.notes || 'No notes entered.')}</p>
          </div>
        </div>
      `;

      els.modalTicketList.insertAdjacentHTML('afterbegin', detailHtml);
      els.modalTicketList.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    }

    function handleBreakdownClick(event) {
      const row = event.target.closest('[data-breakdown-type]');

      if (row) {
        quickBreakdown(row.dataset.breakdownType, row.dataset.breakdownLabel);
      }
    }

    function handleBreakdownKeydown(event) {
      if (event.key !== 'Enter' && event.key !== ' ') return;

      const row = event.target.closest('[data-breakdown-type]');

      if (!row) return;

      event.preventDefault();
      quickBreakdown(row.dataset.breakdownType, row.dataset.breakdownLabel);
    }

    function handleTicketDetailClick(event) {
      const btn = event.target.closest('[data-ticket-detail]');

      if (btn) {
        showTicketDetails(btn.dataset.ticketDetail);
      }
    }

    function closeTicketModal() {
      els.ticketModal.classList.add('hidden');
      els.ticketModal.classList.remove('flex');
    }

    function showError(message) {
      els.errorBox.textContent = message;
      els.errorBox.classList.remove('hidden');
    }

    function hideError() {
      els.errorBox.classList.add('hidden');
      els.errorBox.textContent = '';
    }

    function applyBranding() {
      document.title = CONFIG.dashboardTitle || 'Technology Ticket Dashboard';
      document.getElementById('organizationName').textContent = CONFIG.organizationName || 'Organization Name';
      document.getElementById('dashboardTitle').textContent = CONFIG.dashboardTitle || 'Technology Ticket Dashboard';
    }

    async function loadDashboard() {
      hideError();
      els.refreshBtn.disabled = true;
      els.refreshBtn.textContent = 'Refreshing...';

      try {
        const response = await fetch(CONFIG.apiUrl);

        if (!response.ok) {
          throw new Error(`Dashboard API failed (${response.status})`);
        }

        const data = await response.json();
        const records = data.records || [];

        state.all = records.map(record => normalizeRecord(record));
        state.open = state.all.filter(ticket => ticket.source === 'open');
        state.closed = state.all.filter(ticket => ticket.source === 'closed');

        renderSummary();

        els.lastUpdated.textContent = new Date().toLocaleString([], {
          month: 'short',
          day: 'numeric',
          hour: 'numeric',
          minute: '2-digit'
        });
      } catch (error) {
        console.error(error);
        showError(`${error.message}. Check /api/ticket-dashboard and make sure it returns a records array.`);
      } finally {
        els.refreshBtn.disabled = false;
        els.refreshBtn.textContent = 'Refresh';
      }
    }

    [els.performancePeriodFilter, els.performanceStartDate, els.performanceEndDate].forEach(el => {
      el.addEventListener('change', () => {
        const custom = els.performancePeriodFilter.value === 'custom';
        els.performanceStartDate.disabled = !custom;
        els.performanceEndDate.disabled = !custom;
        renderPerformanceMetrics();
      });
    });

    els.refreshBtn.addEventListener('click', loadDashboard);

    els.storeBreakdown.addEventListener('click', handleBreakdownClick);
    els.patchBreakdown.addEventListener('click', handleBreakdownClick);
    els.otpBreakdown.addEventListener('click', handleBreakdownClick);

    els.storeBreakdown.addEventListener('keydown', handleBreakdownKeydown);
    els.patchBreakdown.addEventListener('keydown', handleBreakdownKeydown);
    els.otpBreakdown.addEventListener('keydown', handleBreakdownKeydown);

    els.modalTicketList.addEventListener('click', handleTicketDetailClick);

    els.closeModal.addEventListener('click', closeTicketModal);

    els.ticketModal.addEventListener('click', event => {
      if (event.target === els.ticketModal) closeTicketModal();
    });

    document.addEventListener('keydown', event => {
      if (event.key === 'Escape') closeTicketModal();
    });

    applyBranding();
    loadDashboard();
    setInterval(loadDashboard, CONFIG.refreshMinutes * 60 * 1000);
  </script>
</body>
</html>
